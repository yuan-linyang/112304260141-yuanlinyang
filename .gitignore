# 忽略敏感信息
*.pem
*.key
*.secret
*.env
.env.local
.env.*.local

# 忽略 Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.so

# 忽略虚拟环境
venv/
env/
ENV/

# 忽略 IDE 配置
.vscode/
.idea/
*.swp
*.swo

# 忽略操作系统文件
.DS_Store
Thumbs.db

# 忽略大型数据集（根据需要调整）
*.zip
*.tar.gz
*.rar

# 忽略模型文件（根据需要调整）
*.h5
*.pth
*.pt
*.bin
*.model

# 忽略日志文件
*.log

# 忽略临时文件
*.tmp
*.temp
